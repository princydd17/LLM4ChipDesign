    %pad/u 4;
    %ix/load 4, 4, 0;
    %flag_set/imm 4, 0;
    %store/vec4 v0x15bf149e0_0, 4, 4;
    %delay 10000, 0;
    %load/vec4 v0x15bf14870_0;
