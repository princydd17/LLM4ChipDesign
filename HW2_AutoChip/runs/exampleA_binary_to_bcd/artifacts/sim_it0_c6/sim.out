 .timescale -9 -12;
    .port_info 0 /INPUT 5 "binary_input";
    .port_info 1 /OUTPUT 8 "bcd_output";
v0x15bf046f0_0 .var "bcd_output", 7 0;
v0x15bf147b0_0 .net "binary_input", 4 0, v0x15bf14930_0;  1 drivers
E_0x15bf04690 .event anyedge, v0x15bf147b0_0;
    .scope S_0x15bf04470;
T_0 ;
