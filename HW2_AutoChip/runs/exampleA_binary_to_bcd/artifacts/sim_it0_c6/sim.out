    .scope S_0x15bf042f0;
T_1 ;
    %vpi_call/w 3 18 "$display", "Testing Binary-to-BCD Converter..." {0 0 0};
    %pushi/vec4 0, 0, 32;
    %store/vec4 v0x15bf14a90_0, 0, 32;
T_1.0 ; Top of for-loop
    %load/vec4 v0x15bf14a90_0;
    %cmpi/s 32, 0, 32;
	  %jmp/0xz T_1.1, 5;
    %load/vec4 v0x15bf14a90_0;
