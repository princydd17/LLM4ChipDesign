    %vpi_call/w 3 33 "$finish" {0 0 0};
T_1.3 ;
T_1.2 ; for-loop step statement
    ; show_stmt_assign_vector: Get l-value for compressed += operand
    %load/vec4 v0x15bf14a90_0;
    %pushi/vec4 1, 0, 32;
    %add;
    %store/vec4 v0x15bf14a90_0, 0, 32;
    %jmp T_1.0;
T_1.1 ; for-loop exit label
    %vpi_call/w 3 37 "$display", "All test cases passed!" {0 0 0};
    %vpi_call/w 3 38 "$finish" {0 0 0};
    %end;
    .thread T_1;
    .scope S_0x15bf042f0;
T_2 ;
    %vpi_call/w 3 43 "$dumpfile", "my_design.vcd" {0 0 0};
    %vpi_call/w 3 44 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x15bf042f0 {0 0 0};
    %end;
    .thread T_2;
    .scope S_0x15bf042f0;
T_3 ;
    %delay 5000, 0;
    %load/vec4 v0x15bf14c30_0;
    %inv;
    %store/vec4 v0x15bf14c30_0, 0, 1;
    %jmp T_3;
    .thread T_3;
