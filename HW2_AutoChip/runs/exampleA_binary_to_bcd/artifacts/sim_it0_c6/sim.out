    %store/vec4 v0x15bf14b40_0, 0, 5;
    %load/vec4 v0x15bf14b40_0;
    %store/vec4 v0x15bf14930_0, 0, 5;
    %load/vec4 v0x15bf14b40_0;
    %pad/u 32;
