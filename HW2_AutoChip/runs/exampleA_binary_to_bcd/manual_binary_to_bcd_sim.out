:vpi_module "/opt/homebrew/Cellar/icarus-verilog/13.0/lib/ivl/va_math.vpi";
:vpi_module "/opt/homebrew/Cellar/icarus-verilog/13.0/lib/ivl/v2009.vpi";
S_0x140e07b30 .scope package, "$unit" "$unit" 2 1;
 .timescale 0 0;
S_0x140e0b3a0 .scope module, "tb_binary_to_bcd_converter" "tb_binary_to_bcd_converter" 3 3;
 .timescale -9 -12;
v0x140e23060_0 .net "bcd_output", 7 0, v0x140e22d20_0;  1 drivers
v0x140e23110_0 .var "binary_input", 4 0;
v0x140e231c0_0 .var "expected_bcd", 7 0;
v0x140e23270_0 .var/i "i", 31 0;
v0x140e23310_0 .var "test_binary", 4 0;
v0x140e23400_0 .var "vcd_clk", 0 0;
S_0x140e0b510 .scope module, "uut" "binary_to_bcd_converter" 3 8, 4 8 0, S_0x140e0b3a0;
 .timescale -9 -12;
    .port_info 0 /INPUT 5 "binary_input";
    .port_info 1 /OUTPUT 8 "bcd_output";
v0x140e07ca0_0 .var "bcd", 7 0;
v0x140e22d20_0 .var "bcd_output", 7 0;
v0x140e22dd0_0 .var "bin", 4 0;
v0x140e22e90_0 .net "binary_input", 4 0, v0x140e23110_0;  1 drivers
v0x140e22f40_0 .var/i "i", 31 0;
E_0x140e08040 .event anyedge, v0x140e22e90_0, v0x140e07ca0_0, v0x140e22dd0_0;
    .scope S_0x140e0b510;
T_0 ;
    %wait E_0x140e08040;
    %pushi/vec4 0, 0, 8;
    %store/vec4 v0x140e07ca0_0, 0, 8;
    %load/vec4 v0x140e22e90_0;
    %store/vec4 v0x140e22dd0_0, 0, 5;
    %pushi/vec4 0, 0, 32;
    %store/vec4 v0x140e22f40_0, 0, 32;
T_0.0 ; Top of for-loop
    %load/vec4 v0x140e22f40_0;
    %cmpi/s 5, 0, 32;
	  %jmp/0xz T_0.1, 5;
    %load/vec4 v0x140e07ca0_0;
    %parti/s 4, 0, 2;
    %pad/u 32;
    %cmpi/u 5, 0, 32;
    %flag_inv 5; GE is !LT
    %jmp/0xz  T_0.3, 5;
    %load/vec4 v0x140e07ca0_0;
    %parti/s 4, 0, 2;
    %addi 3, 0, 4;
    %ix/load 4, 0, 0;
    %flag_set/imm 4, 0;
    %store/vec4 v0x140e07ca0_0, 4, 4;
T_0.3 ;
    %load/vec4 v0x140e07ca0_0;
    %parti/s 4, 4, 4;
    %pad/u 32;
    %cmpi/u 5, 0, 32;
    %flag_inv 5; GE is !LT
    %jmp/0xz  T_0.5, 5;
    %load/vec4 v0x140e07ca0_0;
    %parti/s 4, 4, 4;
    %addi 3, 0, 4;
    %ix/load 4, 4, 0;
    %flag_set/imm 4, 0;
    %store/vec4 v0x140e07ca0_0, 4, 4;
T_0.5 ;
    %load/vec4 v0x140e07ca0_0;
    %load/vec4 v0x140e22dd0_0;
    %concat/vec4; draw_concat_vec4
    %ix/load 4, 1, 0;
    %flag_set/imm 4, 0;
    %shiftl 4;
    %split/vec4 5;
    %store/vec4 v0x140e22dd0_0, 0, 5;
    %store/vec4 v0x140e07ca0_0, 0, 8;
T_0.2 ; for-loop step statement
    %load/vec4 v0x140e22f40_0;
    %addi 1, 0, 32;
    %store/vec4 v0x140e22f40_0, 0, 32;
    %jmp T_0.0;
T_0.1 ; for-loop exit label
    %load/vec4 v0x140e07ca0_0;
    %store/vec4 v0x140e22d20_0, 0, 8;
    %jmp T_0;
    .thread T_0, $push;
    .scope S_0x140e0b3a0;
T_1 ;
    %vpi_call/w 3 18 "$display", "Testing Binary-to-BCD Converter..." {0 0 0};
    %pushi/vec4 0, 0, 32;
    %store/vec4 v0x140e23270_0, 0, 32;
T_1.0 ; Top of for-loop
    %load/vec4 v0x140e23270_0;
    %cmpi/s 32, 0, 32;
	  %jmp/0xz T_1.1, 5;
    %load/vec4 v0x140e23270_0;
    %pad/s 5;
    %store/vec4 v0x140e23310_0, 0, 5;
    %load/vec4 v0x140e23310_0;
    %store/vec4 v0x140e23110_0, 0, 5;
    %load/vec4 v0x140e23310_0;
    %pad/u 32;
    %pushi/vec4 10, 0, 32;
    %mod;
    %pad/u 4;
    %ix/load 4, 0, 0;
    %flag_set/imm 4, 0;
    %store/vec4 v0x140e231c0_0, 4, 4;
    %load/vec4 v0x140e23310_0;
    %pad/u 32;
    %pushi/vec4 10, 0, 32;
    %div;
    %pad/u 4;
    %ix/load 4, 4, 0;
    %flag_set/imm 4, 0;
    %store/vec4 v0x140e231c0_0, 4, 4;
    %delay 10000, 0;
    %load/vec4 v0x140e23060_0;
    %load/vec4 v0x140e231c0_0;
    %cmp/ne;
    %jmp/0xz  T_1.3, 6;
    %vpi_call/w 3 31 "$display", "Error: Test case %0d failed. Expected BCD: 8'b%0b, Got: 8'b%0b", v0x140e23310_0, v0x140e231c0_0, v0x140e23060_0 {0 0 0};
    %vpi_call/w 3 33 "$finish" {0 0 0};
T_1.3 ;
T_1.2 ; for-loop step statement
    ; show_stmt_assign_vector: Get l-value for compressed += operand
    %load/vec4 v0x140e23270_0;
    %pushi/vec4 1, 0, 32;
    %add;
    %store/vec4 v0x140e23270_0, 0, 32;
    %jmp T_1.0;
T_1.1 ; for-loop exit label
    %vpi_call/w 3 37 "$display", "All test cases passed!" {0 0 0};
    %vpi_call/w 3 38 "$finish" {0 0 0};
    %end;
    .thread T_1;
    .scope S_0x140e0b3a0;
T_2 ;
    %vpi_call/w 3 43 "$dumpfile", "my_design.vcd" {0 0 0};
    %vpi_call/w 3 44 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x140e0b3a0 {0 0 0};
    %end;
    .thread T_2;
    .scope S_0x140e0b3a0;
T_3 ;
    %delay 5000, 0;
    %load/vec4 v0x140e23400_0;
    %inv;
    %store/vec4 v0x140e23400_0, 0, 1;
    %jmp T_3;
    .thread T_3;
