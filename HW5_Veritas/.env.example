# Put your key here (NVIDIA: starts with nvapi-). Rename this file to .env
OPENAI_API_KEY=your_openai_or_nvapi_key_here

# Optional alias (also read by veritas_api_setup.py):
# NVIDIA_API_KEY=nvapi-...

# NVIDIA NIM: base URL + model are set automatically for nvapi- keys.
# OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
# OPENAI_MODEL=meta/llama-3.1-8b-instruct

GEMINI_API_KEY=your_gemini_key_here
OPENROUTER_API_KEY=your_openrouter_key_here
